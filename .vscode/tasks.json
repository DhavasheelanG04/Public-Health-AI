{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run React Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"start",
				"--prefix",
				"frontend"
			],
			"isBackground": true
		},
		{
			"label": "Run NLP Backend",
			"type": "shell",
			"command": "d:/hackathon/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"uvicorn",
				"app:app",
				"--reload",
				"--host",
				"127.0.0.1",
				"--port",
				"8000"
			],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true
		}
	]
}